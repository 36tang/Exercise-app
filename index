  {name:'Calf Raises',              cat:'Lower Body', icon:'🦵',focus:'Calves',              cue:"Full range. Pause at top. Slow eccentric down."},
  {name:'Push-Ups',                 cat:'Upper Body', icon:'💪',focus:'Chest / Triceps',     cue:"Chest to floor. Elbows 45° from body. Full lockout at top."},
  {name:'Band Chest Press',         cat:'Upper Body', icon:'💪',focus:'Chest / Triceps',     cue:"Anchor band behind you. 2s squeeze at peak extension."},
  {name:'Band Pull-Aparts',         cat:'Upper Body', icon:'💪',focus:'Upper Back / Posture',cue:"Pull across chest. Squeeze shoulder blades together."},
  {name:'Overhead Press (Alt)',     cat:'Upper Body', icon:'💪',focus:'Shoulders',           cue:"Brace core tight before every lift. Don't arch."},
  {name:'Renegade Rows',            cat:'Upper Body', icon:'💪',focus:'Lats / Abs',          cue:"Plank on dumbbells. Row without rotating hips."},
  {name:'Dumbbell Curl',            cat:'Upper Body', icon:'💪',focus:'Biceps',              cue:"Pin elbows to sides. Full supination at top."},
  {name:'Tricep Dips',              cat:'Upper Body', icon:'💪',focus:'Triceps',             cue:"Lower until elbows 90°. Press through heel of palm."},
  {name:'Face Pulls',               cat:'Upper Body', icon:'💪',focus:'Rear Delts',          cue:"Pull to forehead level. Externally rotate at end."},
  {name:'Rowing Machine',           cat:'Cardio',     icon:'🚣',focus:'Full Body',           cue:"High damper. Explosive leg drive. Lean back slightly at finish."},
  {name:'Jumping Jacks',            cat:'Cardio',     icon:'🚣',focus:'Cardio',              cue:"Arms fully extended overhead. Controlled rhythm."},
  {name:'High Knees',               cat:'Cardio',     icon:'🚣',focus:'Cardio / Core',       cue:"Drive knees to hip height. Pump arms. Stay on balls of feet."},
  {name:'Burpees',                  cat:'Cardio',     icon:'🚣',focus:'Full Body',           cue:"Chest to floor. Explosive jump. Clap overhead."},
  {name:'Jump Rope',                cat:'Cardio',     icon:'🚣',focus:'Cardio',              cue:"Land softly on balls of feet. Keep elbows close to body."},
  {name:'Box Jumps',                cat:'Cardio',     icon:'🚣',focus:'Power / Legs',        cue:"Swing arms. Land softly in squat. Step down, don't jump."},
  {name:'Battle Ropes',             cat:'Cardio',     icon:'🚣',focus:'Cardio / Arms',       cue:"Alternate waves. Keep hips hinged. Drive from shoulders."},
  {name:"Child's Pose",             cat:'Mobility',   icon:'🧘',focus:'Decompression',       cue:"Sit on heels, reach forward. Focus on breathing into lower back."},
  {name:'Hip Flexor Stretch',       cat:'Mobility',   icon:'🧘',focus:'Hip Flexors',         cue:"Lunge position. Tuck pelvis. Feel stretch in front hip."},
  {name:'Thoracic Rotation',        cat:'Mobility',   icon:'🧘',focus:'Thoracic Spine',      cue:"Kneeling. Rotate open as far as possible. Follow hand with eyes."},
  {name:"World's Greatest Stretch", cat:'Mobility',   icon:'🧘',focus:'Full Body Mobility',  cue:"Lunge + rotate + reach. Move slowly through full range."},
  {name:'Cat-Cow',                  cat:'Mobility',   icon:'🧘',focus:'Spine',               cue:"Breathe into each position. Arch and round fully."},
  {name:'Pigeon Pose',              cat:'Mobility',   icon:'🧘',focus:'Hips / Glutes',       cue:"Stay square. Breathe into hip. Hold and relax."},
];

const CATEGORIES = ['All',...new Set(LIBRARY.map(e=>e.cat))];

// ─── STATE ───────────────────────────────────────────────────────────────────
let routineIdx=0, currentIdx=0, currentRound=1;
let phase='idle', timeLeft=0, totalDuration=0;
let timer=null, isPlaying=false, isDark=true;
let customWork=40, customRest=20, customRounds=1;
let customQueue=[], activeCat='All';

// ─── DOM ─────────────────────────────────────────────────────────────────────
const $=id=>document.getElementById(id);
const timerNum=$('timerNum'), phaseLabel=$('phaseLabel');
const exName=$('exName'), exFocus=$('exFocus'), exCue=$('exCue');
const nextRow=$('nextRow'), nextName=$('nextName');
const ringFill=$('ringFill'), mainBtn=$('mainBtn'), btnLabel=$('btnLabel');
const exNum=$('exNum'), exTotal=$('exTotal'), progFill=$('progFill');
const mainView=$('mainView'), doneScreen=$('doneScreen');
const controls=$('controls'), builder=$('builder'), roundBadge=$('roundBadge');
const R=71, CIRC=+(2*Math.PI*R).toFixed(1);

// ─── AUDIO ───────────────────────────────────────────────────────────────────
// iOS Safari / GitHub Pages compatible approach:
// 1. AudioContext is created synchronously on the very first user tap
// 2. An inaudible tone is played immediately to satisfy iOS's gesture requirement
// 3. beep() checks ctx.state === 'running' before playing — if not running, it
//    means the gesture chain was broken and we skip gracefully
let ctx = null;
let audioUnlocked = false;

function unlockAudio() {
  // This runs synchronously inside a tap/click handler — the only place
  // iOS Safari allows audio to start
  if (audioUnlocked) return;
  try {
    ctx = new (window.AudioContext || window.webkitAudioContext)();
    // Play a 1ms silent buffer — this is the iOS unlock handshake
    const buf = ctx.createBuffer(1, ctx.sampleRate * 0.001, ctx.sampleRate);
    const src = ctx.createBufferSource();
    src.buffer = buf;
    src.connect(ctx.destination);
    src.start(0);
    audioUnlocked = true;
  } catch(e) {}
}

function beep(freq, dur, vol) {
  if (!ctx || ctx.state !== 'running') return;
  try {
    const now  = ctx.currentTime;
    const osc  = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.type = 'sine';
    osc.frequency.value = freq;
    gain.gain.setValueAtTime(vol, now);
    gain.gain.exponentialRampToValueAtTime(0.0001, now + dur);
    osc.start(now);
    osc.stop(now + dur + 0.05);
  } catch(e) {}
}

function playCountBeep(s) {
  s === 1 ? beep(880, 0.25, 0.45) : beep(440, 0.08, 0.28);
}

// ─── WAKE LOCK ───────────────────────────────────────────────────────────────
// Must be called with await. Works on HTTPS (GitHub Pages).
// Browser auto-releases it when tab is hidden — we re-acquire on visibilitychange.
let wakeLock = null;

async function acquireWakeLock() {
  if (!('wakeLock' in navigator)) return;
  if (wakeLock !== null) return;
  try {
    wakeLock = await navigator.wakeLock.request('screen');
    wakeLock.addEventListener('release', () => { wakeLock = null; });
  } catch(e) { wakeLock = null; }
}

async function releaseWakeLock() {
  if (!wakeLock) return;
  try { await wakeLock.release(); } catch(e) {}
  wakeLock = null;
}

document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible' && isPlaying) acquireWakeLock();
});

// ─── HELPERS ─────────────────────────────────────────────────────────────────
function routine() { return routineIdx===2 ? customRoutine() : ROUTINES[routineIdx]; }
function exercises() { return routine().exercises; }

function customRoutine() {
  const n=customQueue.length;
  const mins=Math.round(customRounds*n*(customWork+customRest)/60);
  return {
    name:'Custom',label:'Custom Workout',doneTitle:'Workout Complete',doneIcon:'⚡',
    doneSub:()=>`${n} exercises · ${customRounds} round${customRounds>1?'s':''} · ~${mins} min\nNice work.`,
    workTime:customWork,restTime:customRest,rounds:customRounds,exercises:customQueue
  };
}

function updateRing(remaining,total,color) {
  ringFill.style.strokeDashoffset = CIRC*(1-remaining/total);
  ringFill.style.stroke = color;
}

// ─── THEME ───────────────────────────────────────────────────────────────────
function toggleTheme() {
  isDark=!isDark;
  document.body.classList.toggle('light',!isDark);
  $('themeBtn').textContent=isDark?'☀️':'🌙';
}

// ─── ROUTINE SWITCH ───────────────────────────────────────────────────────────
function switchRoutine(idx) {
  clearInterval(timer); isPlaying=false; releaseWakeLock();
  routineIdx=idx; currentIdx=0; currentRound=1; phase='idle';
  document.querySelectorAll('.rtab').forEach((t,i)=>t.classList.toggle('active',i===idx));
  const isCustom=idx===2;
  builder.classList.toggle('show',isCustom);
  mainView.style.display   = isCustom?'none':'';
  controls.style.display   = isCustom?'none':'';
  $('hcount').style.display= isCustom?'none':'';
  doneScreen.classList.remove('show');
  closeList();
  if(!isCustom){ renderExercise(); setIdleState(); btnLabel.textContent='START'; }
}

// ─── RENDER ───────────────────────────────────────────────────────────────────
function renderExercise() {
  const ex=exercises()[currentIdx], len=exercises().length, r=routine();
  exName.textContent=ex.name; exFocus.textContent=ex.focus; exCue.textContent=ex.cue;
  exNum.textContent=currentIdx+1; exTotal.textContent=len;
  roundBadge.textContent=r.rounds>1?`Round ${currentRound} of ${r.rounds}`:'';
  roundBadge.style.display=r.rounds>1?'':'none';
  const totalSteps=len*r.rounds, doneSteps=(currentRound-1)*len+currentIdx;
  progFill.style.width=(doneSteps/totalSteps*100)+'%';
  const hasNext=currentIdx<len-1||currentRound<r.rounds;
  nextRow.style.display=hasNext?'flex':'none';
  if(hasNext) nextName.textContent=currentIdx<len-1?exercises()[currentIdx+1].name:`Round ${currentRound+1} → ${exercises()[0].name}`;
  renderList();
}

// ─── TIMER STATES ─────────────────────────────────────────────────────────────
function setIdleState() {
  phase='idle';
  const wt=routine().workTime;
  timeLeft=totalDuration=wt;
  timerNum.textContent=wt; timerNum.className='timer-number ready';
  phaseLabel.className='phase-label ready'; phaseLabel.textContent='READY';
  updateRing(wt,wt,'var(--accent)'); mainBtn.className='btn btn-primary';
}

function startWork() {
  phase='work'; const wt=routine().workTime; timeLeft=totalDuration=wt;
  timerNum.className='timer-number work';
  phaseLabel.className='phase-label work'; phaseLabel.textContent='WORK';
  mainBtn.className='btn btn-primary';
  updateRing(wt,wt,'var(--accent)'); tick();
}

function startRest() {
  phase='rest'; const rt=routine().restTime; timeLeft=totalDuration=rt;
  timerNum.className='timer-number rest';
  phaseLabel.className='phase-label rest'; phaseLabel.textContent='REST';
  mainBtn.className='btn btn-primary rest-mode';
  updateRing(rt,rt,'var(--rest)'); tick();
}

// ─── TICK ─────────────────────────────────────────────────────────────────────
function tick() {
  clearInterval(timer);
  if(!isPlaying) return;
  timer=setInterval(()=>{
    timeLeft--;
    updateRing(timeLeft,totalDuration,phase==='work'?'var(--accent)':'var(--rest)');
    timerNum.textContent=timeLeft;
    timerNum.classList.toggle('urgent',timeLeft<=5&&timeLeft>0);
    if(timeLeft<=5&&timeLeft>0) playCountBeep(timeLeft);
    if(timeLeft<=0){
      clearInterval(timer); timerNum.classList.remove('urgent');
      if(phase==='work'){
        const r=routine();
        if(currentIdx===exercises().length-1&&currentRound>=r.rounds) finishWorkout();
        else startRest();
      } else {
        if(currentIdx<exercises().length-1){ currentIdx++; }
        else { currentIdx=0; currentRound++; }
        renderExercise(); startWork();
      }
    }
  },1000);
}

// ─── PLAYBACK ─────────────────────────────────────────────────────────────────
async function togglePlay() {
  // MUST call unlockAudio() synchronously here — this IS the user gesture
  unlockAudio();
  if(phase==='idle'){
    isPlaying=true; btnLabel.textContent='PAUSE';
    await acquireWakeLock();
    startWork(); return;
  }
  isPlaying=!isPlaying;
  btnLabel.textContent=isPlaying?'PAUSE':'RESUME';
  if(isPlaying){ await acquireWakeLock(); tick(); }
  else { clearInterval(timer); await releaseWakeLock(); }
}

async function prevExercise() {
  clearInterval(timer); isPlaying=false; await releaseWakeLock();
  if(phase!=='rest'&&currentIdx>0) currentIdx--;
  else if(phase!=='rest'&&currentIdx===0&&currentRound>1){ currentRound--; currentIdx=exercises().length-1; }
  renderExercise(); setIdleState(); btnLabel.textContent='START';
}

function finishWorkout() {
  isPlaying=false; phase='done'; clearInterval(timer); releaseWakeLock();
  mainView.style.display='none'; controls.style.display='none';
  $('doneSub').innerHTML=routine().doneSub(exercises().length).replace('\n','<br>');
  $('doneTitle').textContent=routine().doneTitle;
  $('doneIcon').textContent=routine().doneIcon;
  doneScreen.classList.add('show'); progFill.style.width='100%';
}

function restart() {
  currentIdx=0; currentRound=1; isPlaying=false; phase='idle'; clearInterval(timer);
  doneScreen.classList.remove('show');
  if(routineIdx===2){
    builder.classList.add('show');
    $('hcount').style.display='none';
  } else {
    mainView.style.display=''; controls.style.display='';
    $('hcount').style.display='';
    renderExercise(); setIdleState(); btnLabel.textContent='START';
  }
}

// ─── JUMP LIST ────────────────────────────────────────────────────────────────
function openList() { renderList(); $('listOverlay').classList.add('open'); }
function closeList(){ $('listOverlay').classList.remove('open'); }

function renderList() {
  const r=routine();
  $('listTitle').textContent=r.label;
  $('listMeta').textContent=r.meta||`${exercises().length} exercises · ${r.workTime}s / ${r.restTime}s · ${r.rounds} round${r.rounds>1?'s':''}`;
  $('listScroll').innerHTML=exercises().map((ex,i)=>{
    const cls='list-item'+(i===currentIdx?' active':i<currentIdx?' completed':'');
    return `<div class="${cls}" onclick="jumpTo(${i})">
      <span class="list-num">${i+1}</span>
      <div class="list-info"><div class="list-ex-name">${ex.name}</div><div class="list-ex-focus">${ex.focus}</div></div>
      <div class="list-dot"></div>
    </div>`;
  }).join('');
}

function jumpTo(i) {
  clearInterval(timer); isPlaying=false; currentIdx=i; phase='idle';
  releaseWakeLock(); renderExercise(); setIdleState(); btnLabel.textContent='START'; closeList();
}

// ─── BUILDER ──────────────────────────────────────────────────────────────────
function adjSetting(type,delta) {
  if(type==='work')  { customWork  =Math.max(5,customWork  +delta); $('setWork').textContent  =customWork; }
  if(type==='rest')  { customRest  =Math.max(0,customRest  +delta); $('setRest').textContent  =customRest; }
  if(type==='rounds'){ customRounds=Math.max(1,customRounds+delta); $('setRounds').textContent=customRounds; }
}

function addToQueue(idx) {
  customQueue.push({...LIBRARY[idx]});
  renderQueue(); renderLibrary();
}

function removeFromQueue(idx) {
  customQueue.splice(idx,1);
  renderQueue(); renderLibrary();
}

function clearQueue() { customQueue=[]; renderQueue(); renderLibrary(); }

function renderQueue() {
  $('qCount').textContent=customQueue.length;
  const btn=$('bldStartBtn');
  const q=$('bldQueue');
  if(!customQueue.length){
    q.innerHTML='<div class="bld-empty">Tap exercises below to add them</div>';
    btn.disabled=true; btn.textContent='Add exercises to start'; return;
  }
  btn.disabled=false;
  btn.textContent=`Start Workout · ${customQueue.length} exercise${customQueue.length>1?'s':''}`;
  q.innerHTML=customQueue.map((ex,i)=>`
    <div class="q-item">
      <span class="q-num">${i+1}</span>
      <div class="q-info"><div class="q-name">${ex.name}</div><div class="q-focus">${ex.focus}</div></div>
      <button class="q-remove" onclick="removeFromQueue(${i})">×</button>
    </div>`).join('');
}

function setCat(cat) {
  activeCat=cat;
  document.querySelectorAll('.cat-pill').forEach(p=>p.classList.toggle('active',p.dataset.cat===cat));
  renderLibrary();
}

function renderLibrary() {
  const search=($('libSearch').value||'').toLowerCase();
  const inQueue=new Set(customQueue.map(e=>e.name));
  const filtered=LIBRARY.filter(ex=>{
    const catOk=activeCat==='All'||ex.cat===activeCat;
    const srchOk=!search||ex.name.toLowerCase().includes(search)||ex.focus.toLowerCase().includes(search);
    return catOk&&srchOk;
  });
  $('bldLib').innerHTML=filtered.length?filtered.map(ex=>{
    const added=inQueue.has(ex.name);
    const idx=LIBRARY.findIndex(l=>l.name===ex.name);
    return `<div class="lib-item${added?' added':''}" onclick="addToQueue(${idx})">
      <div class="lib-icon">${ex.icon}</div>
      <div class="lib-info"><div class="lib-name">${ex.name}</div><div class="lib-focus">${ex.focus}</div></div>
      <button class="lib-add" onclick="event.stopPropagation();addToQueue(${idx})">${added?'✓':'+'}</button>
    </div>`;
  }).join(''):'<div class="bld-empty">No exercises match</div>';
}

function renderCategories() {
  $('catScroll').innerHTML=CATEGORIES.map(cat=>
    `<button class="cat-pill${cat===activeCat?' active':''}" data-cat="${cat}" onclick="setCat('${cat}')">${cat}</button>`
  ).join('');
}

async function startCustom() {
  if(!customQueue.length) return;
  // Unlock audio synchronously on this tap before going async
  unlockAudio();
  builder.classList.remove('show');
  mainView.style.display=''; controls.style.display='';
  $('hcount').style.display='';
  currentIdx=0; currentRound=1; phase='idle'; isPlaying=false;
  clearInterval(timer);
  renderExercise(); setIdleState(); btnLabel.textContent='START';
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
renderCategories();
renderQueue();
renderLibrary();
renderExercise();
setIdleState();
</script>
